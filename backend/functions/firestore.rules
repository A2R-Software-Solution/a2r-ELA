rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // User progress collection - users can only read/write their own progress
    match /user_progress/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Essay submissions - users can only read their own submissions
    // Writing is done through Cloud Functions
    match /essay_submissions/{submissionId} {
      allow read: if isAuthenticated() && 
                     resource.data.user_id == request.auth.uid;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}